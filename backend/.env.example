# =============================================================================
# MikroServer Backend — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to version control
# Set NODE_ENV=production only on the actual server — use development locally
# =============================================================================

# --- Application ---
NODE_ENV=development
PORT=3000
API_PREFIX=api
APP_NAME=MikroServer
CORS_ORIGINS=https://dashboard.mikroserver.ci,https://mikroserver.ci

# --- Database ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL=postgresql://mikroserver:CHANGE_ME@postgres:5432/mikroserver?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0
# REDIS_TLS=true  # Enable for managed Redis with TLS

# --- JWT (CRITICAL: generate with: openssl rand -hex 64) ---
JWT_ACCESS_SECRET=GENERATE_WITH_openssl_rand_hex_64_MINIMUM_64_CHARS
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=GENERATE_DIFFERENT_FROM_ACCESS_openssl_rand_hex_64
JWT_REFRESH_EXPIRY=30d

# --- Wave CI Payment ---
WAVE_API_URL=https://api.wave.com/v1
WAVE_API_KEY=wave_prod_XXXXXXXXXXXXX
WAVE_WEBHOOK_SECRET=your_wave_webhook_signing_secret_from_dashboard
WAVE_CURRENCY=XOF
WAVE_CHECKOUT_URL=https://pay.wave.com
WAVE_SUCCESS_URL=https://mikroserver.ci/payment/success
WAVE_ERROR_URL=https://mikroserver.ci/payment/error
# Comma-separated Wave webhook IPs (get from Wave docs)
WAVE_ALLOWED_IPS=198.51.100.1,198.51.100.2

# --- MikroTik RouterOS ---
# These credentials are the RouterOS API user on each router (port 8728).
# Stored per-router in the `routers` table (apiUsername / apiPasswordHash columns).
# These env vars document the expected default — actual values are in the DB.
MIKROTIK_API_USER=BS
MIKROTIK_API_PASSWORD=your_password_here
MIKROTIK_API_TIMEOUT_MS=10000
MIKROTIK_CONNECTION_POOL_SIZE=3
MIKROTIK_DEFAULT_PROFILE=default
MIKROTIK_VOUCHER_PREFIX=MS

# --- Queue (BullMQ) ---
QUEUE_VOUCHER_DELIVERY_ATTEMPTS=5
QUEUE_VOUCHER_DELIVERY_BACKOFF_MS=5000
QUEUE_CONCURRENCY=5

# --- Circuit Breaker ---
CIRCUIT_BREAKER_TIMEOUT_MS=10000
CIRCUIT_BREAKER_RESET_MS=30000
CIRCUIT_BREAKER_THRESHOLD=50

# --- VPS public IP + port-mapping range ---
VPS_PUBLIC_IP=139.84.241.27
PORT_MAP_RANGE_START=19000
PORT_MAP_RANGE_END=19999

# --- Encryption (router access credentials, AES-256-GCM) ---
# Generate with: openssl rand -hex 64
ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_hex_64_MINIMUM_64_CHARS

# --- Security ---
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100
WEBHOOK_RATE_LIMIT_MAX=200
ARGON2_MEMORY=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# --- Web Push (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=GENERATE_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=GENERATE_VAPID_PRIVATE_KEY
VAPID_EMAIL=mailto:admin@mikroserver.ci

# --- Logging ---
LOG_LEVEL=info
LOG_PRETTY=false

# --- Transactions ---
TRANSACTION_EXPIRY_MINUTES=30

# --- Metrics ---
METRICS_ENABLED=true
SNAPSHOT_CRON=0 0 * * *

# =============================================================================
# Docker Compose variables (infrastructure/.env)
# =============================================================================
# POSTGRES_DB=mikroserver
# POSTGRES_USER=mikroserver
# POSTGRES_PASSWORD=CHANGE_ME
# REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
# JWT_ACCESS_SECRET=...
# JWT_REFRESH_SECRET=...
# WAVE_API_KEY=...
# WAVE_WEBHOOK_SECRET=...
# WAVE_SUCCESS_URL=https://mikroserver.ci/payment/success
# WAVE_ERROR_URL=https://mikroserver.ci/payment/error
# WAVE_ALLOWED_IPS=...
# API_URL=https://api.mikroserver.ci
