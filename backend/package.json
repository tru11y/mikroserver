{
  "name": "@mikroserver/backend",
  "version": "1.0.0",
  "description": "MikroServer - WiFi Monetization Platform API",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "cross-env RUN_TESTCONTAINERS_E2E=true jest --config ./test/jest-e2e.json",
    "openapi:generate": "ts-node scripts/generate-openapi.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "admin:recover": "node prisma/recover_admin.js",
    "admin:list": "node prisma/recover_admin.js --list"
  },
  "dependencies": {
    "@bull-board/api": "^5.14.3",
    "@bull-board/fastify": "^5.14.3",
    "@fastify/compress": "^8.0.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-fastify": "^11.1.16",
    "@nestjs/platform-ws": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.18",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.57.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.1",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.57.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.30.1",
    "@prisma/client": "^6.19.3",
    "@types/nodemailer": "^7.0.11",
    "@types/ssh2": "^1.15.5",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "argon2": "^0.44.0",
    "axios": "^1.6.7",
    "axios-retry": "^4.1.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.4.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.3.1",
    "fastify": "^5.8.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "luxon": "^3.4.4",
    "mikrotik": "^1.0.12",
    "nanoid": "^3.3.11",
    "nestjs-pino": "^4.0.0",
    "nodemailer": "^8.0.4",
    "opossum": "^8.1.3",
    "otplib": "^13.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.17.2",
    "pino": "^8.19.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.0.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "ssh2": "^1.17.0",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.0.0",
    "@types/argon2": "^0.14.1",
    "@types/bcrypt": "^5.0.2",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.14",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.19.37",
    "@types/opossum": "^8.1.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "prisma": "^6.19.3",
    "supertest": "^7.0.0",
    "testcontainers": "^10.21.0",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
