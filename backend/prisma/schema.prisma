model BoostTier {
  id              String        @id @default(uuid()) @db.Uuid
  name            String        @db.VarChar(100)
  downloadKbps    Int           @map("download_kbps")
  uploadKbps      Int           @map("upload_kbps")
  durationMinutes Int           @map("duration_minutes")
  priceXof        Int           @map("price_xof")
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  transactions    Transaction[]
  boosts          SpeedBoost[]

  @@map("boost_tiers")
}

model SpeedBoost {
  id                String      @id @default(uuid()) @db.Uuid
  sessionId         String      @map("session_id") @db.Uuid
  tierId            String      @map("tier_id") @db.Uuid
  transactionId     String?     @unique @map("transaction_id") @db.Uuid
  routerId          String      @map("router_id") @db.Uuid
  voucherUsername   String      @map("voucher_username") @db.VarChar(50)
  status            BoostStatus @default(PENDING)
  appliedAt         DateTime?   @map("applied_at")
  expiresAt         DateTime?   @map("expires_at")
  revertedAt        DateTime?   @map("reverted_at")
  originalRateLimit String?     @map("original_rate_limit") @db.VarChar(50)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  session           Session     @relation(fields: [sessionId], references: [id])
  tier              BoostTier   @relation(fields: [tierId], references: [id])
  transaction       Transaction? @relation(fields: [transactionId], references: [id])

  @@index([status])
  @@index([sessionId])
  @@index([expiresAt])
  @@map("speed_boosts")
}

model CommissionPayout {
  id            String         @id @default(uuid()) @db.Uuid
  resellerId    String         @map("reseller_id") @db.Uuid
  amountXof     Int            @map("amount_xof")
  status        PayoutStatus   @default(REQUESTED)
  requestedAt   DateTime       @default(now()) @map("requested_at")
  processedAt   DateTime?      @map("processed_at")
  waveReference String?        @map("wave_reference") @db.VarChar(255)
  notes         String?        @db.VarChar(1000)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  reseller      ResellerConfig @relation(fields: [resellerId], references: [id])

  @@index([resellerId])
  @@index([status])
  @@map("commission_payouts")
}

model ChurnScore {
  id               String     @id @default(uuid()) @db.Uuid
  userId           String     @unique @map("user_id") @db.Uuid
  score            Int
  riskLevel        ChurnRisk  @map("risk_level")
  prevRiskLevel    ChurnRisk? @map("prev_risk_level")
  factors          Json
  lastCalculatedAt DateTime   @default(now()) @map("last_calculated_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  user             User       @relation(fields: [userId], references: [id])

  @@map("churn_scores")
}
