    "expo-file-system": "~19.0.21",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.0",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "5.6.0",
    "react-native-screens": "~4.16.0",
