# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/mikroserver
DATABASE_USER=mikroserver
DATABASE_PASSWORD=change_me_in_production

# Redis
REDIS_URL=redis://localhost:6379

# JWT (RS256)
JWT_PRIVATE_KEY_PEM=/path/to/private.pem
JWT_PUBLIC_KEY_PEM=/path/to/public.pem
JWT_ISSUER=mikroserver
JWT_AUDIENCE=mikroserver-api
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# Wave Mobile Money
WAVE_WEBHOOK_SECRET=your_wave_hmac_secret
WAVE_API_BASE_URL=https://api.wave.com/v1
WAVE_API_KEY=your_wave_api_key

# WireGuard
WG_INTERFACE=wg0
WG_SERVER_ADDRESS=10.66.66.1
WG_SUBNET=10.66.66.0/24
WG_SERVER_PORT=51820
WG_SERVER_ENDPOINT=your.vps.ip:51820
WG_SERVER_PUBLIC_KEY=base64_encoded_server_public_key

# CORS
CORS_ALLOWED_ORIGINS=https://dashboard.example.com,https://app.example.com

# App
PORT=8080
ENVIRONMENT=development
